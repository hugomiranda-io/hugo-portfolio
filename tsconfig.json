{
 "extends": "astro/tsconfigs/strict",
 "include": [".astro/types.d.ts", "**/*"],
 "exclude": ["dist"],
 "compilerOptions": {
  "jsx": "react-jsx",
  "jsxImportSource": "react",
  "paths": {
   "@layouts/*": ["./src/layouts/*"],
   "@pages/*": ["./src/pages/*"],
   "@components": ["./src/components"],
   "@types": ["./src/types"],
   "@data": ["./src/data"],
   "@styles/*": ["./src/styles/*"]
  }
 }
}
