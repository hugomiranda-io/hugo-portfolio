---
import { createMarkdownProcessor } from "@astrojs/markdown-remark";
import { getCollection } from "astro:content";

import { IntroText, StackList, Timeline } from "@components";
import { PROFILE_DATA } from "@data";
import Layout from "@layouts/Layout.astro";

const timelineEntries = await getCollection("timeline");
const markdown = await createMarkdownProcessor();

type TimelineEntry = (typeof timelineEntries)[number];

function isCareerEntry(entry: TimelineEntry): entry is TimelineEntry & {
 data: TimelineEntry["data"] & { variant: "career"; startPeriod: number; endPeriod: number };
} {
 return entry.data.variant === "career";
}

function isEducationEntry(entry: TimelineEntry): entry is TimelineEntry & {
 data: TimelineEntry["data"] & { variant: "education"; endPeriod: number };
} {
 return entry.data.variant === "education";
}

const career = await Promise.all(
 timelineEntries
  .filter(isCareerEntry)
  .sort((a, b) => b.data.startPeriod - a.data.startPeriod)
  .map(async (entry) => {
   const { code } = await markdown.render(entry.body ?? "");
   return { id: entry.id, ...entry.data, contentHtml: code };
  }),
);

const education = timelineEntries
 .filter(isEducationEntry)
 .sort((a, b) => b.data.endPeriod - a.data.endPeriod)
 .map((entry) => ({ id: entry.id, ...entry.data }));
---

<Layout>
 <IntroText />
 <StackList data={PROFILE_DATA.techStack} />
 <Timeline client:load career={career} education={education} />
</Layout>
