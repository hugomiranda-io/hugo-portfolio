---
import { Hero, TileGroup } from "@components";
import { KEYHIGHLIGHTS_DATA, LINKS } from "@data";
import Layout from "@layouts/Layout.astro";
import type { TileProps } from "@types";

const featuredSocials = ["github", "figma", "dribbble"] as const;

const keySocialTiles: TileProps[] = featuredSocials.map((key) => {
 const item = LINKS.socials[key];
 return {
  as: "a" as const,
  externalLink: true,
  href: item.href,
  title: item.label,
  description: item.description,
  icon: item.icon,
 };
});
---

<Layout
 title="Hugo Miranda | Développeur Front-End & UI Designer"
 description="Développeur front-end & UI designer avec 5+ ans d'expérience. Expert React, TypeScript, Salesforce Lightning et accessibilité WCAG. Basé à Paris."
>
 <Hero />
 <TileGroup data={KEYHIGHLIGHTS_DATA} />
 <TileGroup title="Mes profils" data={keySocialTiles} />
</Layout>
