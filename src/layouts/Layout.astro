---
import Analytics from "@vercel/analytics/astro";
import { ClientRouter } from "astro:transitions";
import { SEO } from "astro-seo";

import { Footer, Header } from "@components";
import "@styles/index.scss";

const generator = Astro.generator;
const currentPath = Astro.url.pathname;

interface Props {
 title: string;
 description?: string;
 canonical?: string;
 noindex?: boolean;
 ogImage?: string;
 ogImageAlt?: string;
}

const {
 title,
 description,
 canonical,
 noindex = false,
 ogImage = "/siteImage.png",
 ogImageAlt = "Aperçu du site Hugo Miranda",
} = Astro.props;

const siteUrl = Astro.site ?? new URL(Astro.url.origin);
const canonicalUrl = canonical
 ? new URL(canonical, siteUrl).toString()
 : new URL(`${Astro.url.pathname}${Astro.url.search}`, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();
const isDefaultOgImage = ogImage === "/siteImage.png";

const personSchema = {
 "@context": "https://schema.org",
 "@type": "Person",
 "@id": "https://hugomiranda.io/#person",
 name: "Hugo Miranda",
 jobTitle: "Développeur Front-End & UI Designer",
 url: "https://hugomiranda.io",
 sameAs: [
  "https://www.linkedin.com/in/hugomiranda-io",
  "https://github.com/hugomiranda-io",
  "https://www.figma.com/@hugomiranda_io",
  "https://dribbble.com/hugomiranda-io",
  "https://www.instagram.com/hugomiranda_io",
 ],
 address: {
  "@type": "PostalAddress",
  addressLocality: "Paris",
  addressCountry: "FR",
 },
 knowsAbout: [
  "JavaScript",
  "React.js",
  "TypeScript",
  "Salesforce Lightning",
  "Figma",
  "UI Design",
  "Accessibilité WCAG",
  "Design Systems",
 ],
};
---

<html lang="fr">
 <head>
  <SEO
   title={title}
   description={description}
   canonical={canonicalUrl}
   noindex={noindex}
   robotsExtras="max-snippet:-1, max-image-preview:large, max-video-preview:-1"
   languageAlternates={[
    { href: canonicalUrl, hrefLang: "fr-FR" },
    { href: canonicalUrl, hrefLang: "x-default" },
   ]}
   openGraph={{
    basic: {
     title,
     type: "website",
     image: ogImageUrl,
     url: canonicalUrl,
    },
    optional: {
     description,
     locale: "fr_FR",
     siteName: "Hugo Miranda - Portfolio",
    },
    image: {
     alt: ogImageAlt,
     ...(isDefaultOgImage
      ? {
         type: "image/png",
         width: 1200,
         height: 630,
        }
      : {}),
    },
   }}
   twitter={{
    card: "summary_large_image",
    title,
    description,
    image: ogImageUrl,
    imageAlt: ogImageAlt,
   }}
   extend={{
    meta: [
     { name: "author", content: "Hugo Miranda" },
     { name: "theme-color", content: "#0c0c0c" },
    ],
   }}
  />
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width" />
  <meta name="generator" content={generator} />
  <Analytics />
  <ClientRouter />
 </head>
 <body class="surface-app">
  <Header currentPath={currentPath} />
  <main class="container-app mx-auto pt-5xl pb-5xl">
   <div class="flex flex-col gap-4xl">
    <slot />
   </div>
  </main>
  <Footer />
 </body>
</html>
